#!/bin/sh

# Auto-sync latest commit to Google Apps Script.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$REPO_ROOT" ]; then
  exit 0
fi

cd "$REPO_ROOT" || exit 0

if command -v clasp >/dev/null 2>&1; then
  clasp push
else
  echo "post-commit: clasp is not installed or not on PATH; skipping Apps Script sync."
fi