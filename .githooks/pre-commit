#!/bin/sh

# Enforced check: require README updates when behavior/config changed.
CHANGED="$(git diff --cached --name-only)"

if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "$CHANGED" | grep -Eq '^(Code\.gs|appsscript\.json|\.clasp\.json|\.githooks/.*|README\.md)$'
TOUCHED_KEY_FILES=$?

echo "$CHANGED" | grep -Eq '^README\.md$'
TOUCHED_README=$?

if [ "$TOUCHED_KEY_FILES" -eq 0 ] && [ "$TOUCHED_README" -ne 0 ]; then
  echo "pre-commit: README.md is required when code/config/workflow files change."
  echo "Stage README.md and commit again."
  echo "To bypass once: git commit --no-verify"
  exit 1
fi

exit 0